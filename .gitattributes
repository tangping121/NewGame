# 统一仓库内文本文件换行为 LF，避免 Windows/Unix 协作时的 CRLF 噪音
* text=auto eol=lf

# 明确文本类型
*.go      text eol=lf
*.mod     text eol=lf
*.sum     text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.sql     text eol=lf
*.proto   text eol=lf
*.sh      text eol=lf

# Windows 脚本保留 CRLF
*.ps1     text eol=crlf
*.bat     text eol=crlf

# 二进制文件不做换行转换
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.pdf     binary
*.zip     binary
*.exe     binary
